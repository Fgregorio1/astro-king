---
interface Props {
  lang?: "pt" | "es";
}

const { lang = "pt" } = Astro.props;
const isEs = lang === "es";

const t = isEs
  ? {
      pill: "Casos de éxito",
      title: "Conviértete en nuestra próxima historia de éxito",
    }
  : {
      pill: "Cases de sucesso",
      title: "Seja nosso próximo case de sucesso",
    };
---

<section class="bg-gradient-to-b from-[#111] to-black text-white py-24 md:py-32 relative overflow-hidden">
  <div class="container mx-auto px-4 max-w-[1400px] relative z-10">
    <div class="text-center mb-16">
      <span class="inline-block bg-zinc-800 text-primary px-6 py-2 rounded-full text-xs font-bold uppercase tracking-[0.2em] mb-6 shadow-[0_0_15px_rgba(208,242,36,0.15)]">
        {t.pill}
      </span>
      <h2 class="font-heading text-5xl md:text-7xl uppercase tracking-tight leading-none mb-12">
        {t.title}
      </h2>
    </div>

    <!-- Swiper Container -->
    <div class="swiper case-study-slider w-full pb-16">
      <div class="swiper-wrapper">
        
        <!-- Slide 1 -->
        <div class="swiper-slide max-w-[300px] md:max-w-[350px]">
          <a href="#" class="block relative group overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/assets/images/tile-nimble.png" alt="Nimble Transformation" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full p-8 transition-transform duration-500 transform translate-y-4 group-hover:translate-y-0">
              <p class="font-heading text-3xl md:text-4xl uppercase leading-tight">Nimble<br/>Transformation</p>
              <div class="w-12 h-1 bg-primary mt-4 transform scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
            </div>
          </a>
        </div>

        <!-- Slide 2 -->
        <div class="swiper-slide max-w-[300px] md:max-w-[350px]">
          <a href="#" class="block relative group overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/assets/images/tile-scotland.png" alt="Scotland Titles" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full p-8 transition-transform duration-500 transform translate-y-4 group-hover:translate-y-0">
              <p class="font-heading text-3xl md:text-4xl uppercase leading-tight">Scotland<br/>Titles</p>
              <div class="w-12 h-1 bg-primary mt-4 transform scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
            </div>
          </a>
        </div>

        <!-- Slide 3 -->
        <div class="swiper-slide max-w-[300px] md:max-w-[350px]">
          <a href="#" class="block relative group overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/assets/images/tile-muscle.png" alt="My Muscle Chef" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full p-8 transition-transform duration-500 transform translate-y-4 group-hover:translate-y-0">
              <p class="font-heading text-3xl md:text-4xl uppercase leading-tight">My Muscle<br/>Chef</p>
              <div class="w-12 h-1 bg-primary mt-4 transform scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
            </div>
          </a>
        </div>

        <!-- Slide 4 -->
        <div class="swiper-slide max-w-[300px] md:max-w-[350px]">
          <a href="#" class="block relative group overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/assets/images/tile-rentbuy.png" alt="Rent Buy It" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full p-8 transition-transform duration-500 transform translate-y-4 group-hover:translate-y-0">
              <p class="font-heading text-3xl md:text-4xl uppercase leading-tight">Rent<br/>Buy It</p>
              <div class="w-12 h-1 bg-primary mt-4 transform scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
            </div>
          </a>
        </div>
        
        <!-- Slide 5 -->
        <div class="swiper-slide max-w-[300px] md:max-w-[350px]">
          <a href="#" class="block relative group overflow-hidden rounded-2xl aspect-[3/4]">
            <img src="/assets/images/tile-ugg.png" alt="Original UGG" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-full p-8 transition-transform duration-500 transform translate-y-4 group-hover:translate-y-0">
              <p class="font-heading text-3xl md:text-4xl uppercase leading-tight">Original UGG<br/>Australia Classic</p>
              <div class="w-12 h-1 bg-primary mt-4 transform scale-x-0 origin-left transition-transform duration-500 group-hover:scale-x-100"></div>
            </div>
          </a>
        </div>

      </div>
      
      <!-- Swiper Pagination -->
      <div class="swiper-pagination mt-8 relative"></div>
    </div>
  </div>
</section>

<!-- Include Swiper CSS & JS locally via CDN for this specific component -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.case-study-slider', {
      slidesPerView: 'auto',
      spaceBetween: 30,
      centeredSlides: true,
      loop: true,
      grabCursor: true,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
          centeredSlides: false,
        },
        1024: {
          slidesPerView: 3,
          centeredSlides: false,
        },
        1280: {
          slidesPerView: 4,
          centeredSlides: false,
        }
      }
    });
  });
</script>

<style>
  /* Custom Swiper Styles to match theme */
  :root {
    --swiper-theme-color: #d0f224; /* Primary lime green */
  }
  .swiper-pagination-bullet {
    background: #555;
    opacity: 1;
  }
  .swiper-pagination-bullet-active {
    background: var(--swiper-theme-color);
  }
</style>
