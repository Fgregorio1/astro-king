---
interface Props {
  lang?: "pt" | "es";
}

const { lang = "pt" } = Astro.props;
const isEs = lang === "es";

const now = new Date();
const updatedDate = new Intl.DateTimeFormat(isEs ? "es-ES" : "pt-BR", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(now);

const t = isEs
  ? {
      updated: `Actualizado: ${updatedDate}`,
      salutation: "Querido dueño de negocio,",

      hook: "Ya estuvimos en tus zapatos.",
      line1: "Despertando antes del sol.",
      line2: "Herramientas en la camioneta. Café en la mano.",
      line3: "Construyendo algo real — para tu familia, para tu futuro.",

      question: "¿Y hacer crecer un negocio en este país?",
      hard: "Es difícil. **Difícil, de ver*as.**",

      pain1: "Probablemente estás preocupado de dónde va a venir el próximo cliente.",
      pain2: "No cualquier cliente — uno que realmente valore tu trabajo.",
      pain3: "Uno que no te subestime por tu acento o por tu nombre.",

      stressed:
        "Estresado. Durmiendo como bebé con cólicos y gallo en el mismo cuarto.",

      everyoneHeader: "Y mientras tanto, todo el mundo tiene una opinión:",
      voice1: '"Necesitas un sitio web, mano."',
      voice2: '"Métete al TikTok — ¡es marketing gratis!"',
      voice3:
        '"Necesitas reseñas en Google, anuncios en Facebook, ¡un logo que se vea profesional!"',

      selfIntro: "Y entonces empiezas a preguntarte:",
      q1: "¿Debería postear en Instagram todos los días?",
      q2: "¿Crear un perfil en Instagram?",
      q3: "¿Correr anuncios en Google?",
      q4: "¿Montar un programa de referidos?",
      q5: "¿Gastar $3k en un logo?",

      scream: "*por el amor de Dios, que alguien me ayude*",

      notAlone:
        "Mira — a la mayoría de los dueños de negocios de servicios que están empezando les pasa esto…",
      confused1: "Es un sentimiento confuso…",
      confused2: 'Mezclado con "tengo que hacerlo todo solo"…',
      confused3: 'Sazonado con "no sé en quién confiar."',

      syndrome:
        "Le llamamos a esto **el síndrome del Inmigrante**.",

      describe1:
        "Una zona caliente, sofocante y confusa donde crees que eres empresario porque abriste una LLC — pero te convertiste en el empleado peor pagado de la empresa.",
      describe2:
        "Y piensas que vender tu trabajo 40% más barato para no tener el calendario vacío va a resolver tus problemas.",

      bridge: "Pero aquí va la verdad — **existe una solución**.",

      heroIntro:
        "Tal vez no lo sepas, pero en los ojos de un Americano, eres un **súper héroe**.",
      heroParen: "(Y la persona correcta para resolver sus problemas.)",

      traits: "Tu habilidad. Tu confiabilidad. Tu palabra.",
      traitsGold: "**Eso es oro.**",

      promise:
        "Solo necesitas el sistema correcto para transformar eso en un flujo constante de clientes, reseñas de 5 estrellas y referidos — sin el caos.",

      closing: "Todo comienza eligiendo tu camino a continuación…",
    }
  : {
      updated: `Atualizado: ${updatedDate}`,
      salutation: "Querido dono de negócio,",

      hook: "Já estivemos na sua pele.",
      line1: "Acordando antes do sol.",
      line2: "Ferramentas no carro. Café na mão.",
      line3: "Construindo algo real — pra sua família, pro seu futuro.",

      question: "E fazer um negócio crescer nesse país?",
      hard: "É difícil. **Difícil, pra c*ralho.**",

      pain1: "Você provavelmente está preocupado de onde vai vir o próximo cliente.",
      pain2: "Não qualquer cliente — um que realmente valorize o seu trabalho.",
      pain3: "Um que não te subestime por causa do seu sotaque ou do seu nome.",

      stressed:
        "Estressado. Dormindo igual bebê com cólica e galo no mesmo quarto.",

      everyoneHeader: "E enquanto isso, todo mundo tem uma opinião:",
      voice1: '"Você precisa de um site, mano."',
      voice2: '"Entra no TikTok — é marketing de graça!"',
      voice3:
        '"Precisa de avaliações no Google, anúncio no Facebook, um logo que pareça profissional!"',

      selfIntro: "E aí você começa a se perguntar:",
      q1: "Devo postar no Instagram todo dia?",
      q2: "Criar perfil no Instagram?",
      q3: "Rodar anúncio no Google?",
      q4: "Montar um programa de indicações?",
      q5: "Gastar $3k num logo?",

      scream: "*pelo amor de Deus, alguém me ajuda*",

      notAlone:
        "Olha — a maioria dos donos de negócios de serviços que estão começando passa por isso…",
      confused1: "É um sentimento confuso…",
      confused2: 'Misturado com "tenho que fazer tudo sozinho"…',
      confused3: 'Temperado com "não sei em quem confiar."',

      syndrome:
        "A gente chama isso de **síndrome do Imigrante**.",

      describe1:
        "Uma zona quente, abafada e confusa onde você acha que é empresário porque abriu uma LLC — mas virou o empregado menos pago da empresa.",
      describe2:
        "E acha que vender seu trabalho 40% mais barato pra não ficar com o calendário vazio vai resolver seus problemas.",

      bridge: "Mas aqui vai a verdade — **existe uma solução**.",

      heroIntro:
        "Talvez você não saiba, mas nos olhos de um Americano, você é um **super herói**.",
      heroParen: "(E a pessoa certa que vai resolver os problemas dele.)",

      traits: "Sua habilidade. Sua confiabilidade. Sua palavra.",
      traitsGold: "**Isso é ouro.**",

      promise:
        "Você só precisa do sistema certo pra transformar isso num fluxo constante de clientes, avaliações 5 estrelas e indicações — sem o caos.",

      closing: "Tudo começa escolhendo o seu caminho abaixo…",
    };

// Inline markdown-ish renderer: **bold** and *italic* → HTML.
// Kept tiny on purpose; only used on copy we control above.
function renderInline(s: string): string {
  return s
    .replace(/\\\*/g, "&#42;")
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/\*(.+?)\*/g, "<em>$1</em>")
    .replace(/&#42;/g, "*");
}
---

<section class="py-24 md:py-32 bg-[#f4f4f5] text-zinc-900 border-t-8 border-primary">
  <div class="container mx-auto px-4">
    <article class="mx-auto max-w-2xl font-sans text-zinc-800">
      <p class="mb-10 text-sm font-medium uppercase tracking-widest text-zinc-500">
        {t.updated}
      </p>

      <p class="mb-6 text-lg md:text-xl font-medium text-zinc-900">
        {t.salutation}
      </p>

      <div class="space-y-6 text-lg md:text-xl leading-relaxed">
        <p>{t.hook}</p>

        <p>{t.line1}</p>
        <p>{t.line2}</p>
        <p>{t.line3}</p>

        <p>{t.question}</p>
        <p set:html={renderInline(t.hard)} />

        <p>{t.pain1}</p>
        <p>{t.pain2}</p>
        <p>{t.pain3}</p>

        <p>{t.stressed}</p>

        <p>{t.everyoneHeader}</p>

        <p>{t.voice1}</p>
        <p>{t.voice2}</p>
        <p>{t.voice3}</p>

        <p>{t.selfIntro}</p>

        <p>{t.q1}</p>
        <p>{t.q2}</p>
        <p>{t.q3}</p>
        <p>{t.q4}</p>
        <p>{t.q5}</p>

        <p set:html={renderInline(t.scream)} />

        <p>{t.notAlone}</p>
        <p>{t.confused1}</p>
        <p>{t.confused2}</p>
        <p>{t.confused3}</p>

        <p set:html={renderInline(t.syndrome)} />

        <p>{t.describe1}</p>
        <p>{t.describe2}</p>

        <p set:html={renderInline(t.bridge)} />

        <p set:html={renderInline(t.heroIntro)} />
        <p class="text-zinc-600"><em>{t.heroParen}</em></p>

        <p>{t.traits}</p>
        <p set:html={renderInline(t.traitsGold)} />

        <p>{t.promise}</p>

        <p>{t.closing}</p>
      </div>
    </article>
  </div>
</section>
