---
interface Props {
  lang?: "pt" | "es";
}

const { lang = "pt" } = Astro.props;
const isEs = lang === "es";

const t = isEs
  ? {
      hook: "Oye. Ya estuvimos en tus zapatos.",
      line1: "Despertando antes del sol.",
      line2: "Herramientas en la camioneta. Café en la mano.",
      line3: "Construyendo algo real — para tu familia, para tu futuro.",

      question: "¿Y hacer crecer un negocio en este país?",
      hardLead: "Es",
      hardWord: "difícil",
      hardEmphasis: "Difícil, de ver*as.",

      pain1: "Probablemente estás preocupado de dónde va a venir el próximo cliente.",
      pain2: "No cualquier cliente — uno que realmente valore tu trabajo.",
      pain3: "Uno que no te subestime por tu acento o por tu nombre.",

      stressed:
        "Estás estresado. Durmiendo como bebé con cólicos y gallo en el mismo cuarto.",

      everyoneHeader: "Y mientras tanto, todo el mundo tiene una opinión:",
      voice1: '"Necesitas un sitio web, mano."',
      voice2: '"Métete al TikTok — ¡es marketing gratis!"',
      voice3:
        '"Necesitas reseñas en Google, anuncios en Facebook, ¡un logo que se vea profesional!"',

      selfIntro: "Y entonces empiezas a preguntarte:",
      q1: "¿Debería postear en Instagram todos los días?",
      q2: "¿Crear un perfil en Instagram?",
      q3: "¿Correr anuncios en Google?",
      q4: "¿Montar un programa de referidos?",
      q5: "¿Gastar $3k en un logo?",

      scream: "¡Por el amor de Dios, que alguien me ayude!",

      notAlone:
        "Mira — la mayoría de los dueños de negocios de servicios que están empezando pasan por esto…",
      confused1: "Es un sentimiento confuso…",
      confused2: "Mezclado con \"tengo que hacerlo todo solo\"…",
      confused3: "Sazonado con \"no sé en quién confiar.\"",

      callLead: "Yo le llamo a esto",
      callName: "El síndrome del Inmigrante.",

      describe1:
        "Una zona caliente, sofocante y confusa donde crees que eres empresario porque abriste una LLC — pero te convertiste en el empleado peor pagado de la empresa.",
      describe2:
        "Y piensas que vender tu trabajo 40% más barato para no tener el calendario vacío va a resolver tus problemas.",

      bridgeLead: "Pero aquí va la verdad —",
      bridgeName: "Existe una solución.",

      heroIntro: "Tal vez no lo sepas, pero en los ojos de un Americano…",
      heroLead: "Eres un",
      heroWord: "súper héroe",
      heroParen: "(Y la persona correcta para resolver sus problemas).",
      traits: "Tu habilidad. Tu confiabilidad. Tu palabra.",
      traitsGold: "Eso es oro.",

      promise:
        "Solo necesitas el sistema correcto para transformar eso en un flujo constante de clientes, reseñas de 5 estrellas y referidos que siguen llegando a la palma de tus manos — sin el caos.",

      ctaTitle: "Entonces, desde donde estés empezando…",
      ctaSubtitle: "Todo comienza eligiendo tu camino abajo.",
      ctaPrimary: "Contrátanos para hacerlo por ti",
      ctaSecondary: "Aprende a hacerlo tú mismo",
    }
  : {
      hook: "Ei. Já estivemos na sua pele.",
      line1: "Acordando antes do sol.",
      line2: "Ferramentas no carro. Café na mão.",
      line3: "Construindo algo real — pra sua família, pro seu futuro.",

      question: "E fazer um negócio crescer nesse país?",
      hardLead: "É",
      hardWord: "difícil",
      hardEmphasis: "Difícil, pra c*ralho.",

      pain1: "Você provavelmente está preocupado de onde vai vir o próximo cliente.",
      pain2: "Não qualquer cliente — um que realmente valorize o seu trabalho.",
      pain3: "Um que não te subestime por causa do seu sotaque ou do seu nome.",

      stressed:
        "Você está estressado. Dormindo igual bebê com cólica e galo no mesmo quarto.",

      everyoneHeader: "E enquanto isso, todo mundo tem uma opinião:",
      voice1: '"Você precisa de um site, mano."',
      voice2: '"Entra no TikTok — é marketing de graça!"',
      voice3:
        '"Precisa de avaliações no Google, anúncio no Facebook, um logo que pareça profissional!"',

      selfIntro: "E aí você começa a se perguntar:",
      q1: "Devo postar no Instagram todo dia?",
      q2: "Criar perfil no Instagram?",
      q3: "Rodar anúncio no Google?",
      q4: "Montar um programa de indicações?",
      q5: "Gastar $3k num logo?",

      scream: "Pelo amor de Deus, alguém me ajuda!",

      notAlone:
        "Olha — a maioria dos donos de negócios de serviços que estão começando passam por isso…",
      confused1: "É um sentimento confuso…",
      confused2: "Misturado com \"tenho que fazer tudo sozinho\"…",
      confused3: "Temperado com \"não sei em quem confiar.\"",

      callLead: "Eu chamo isso de",
      callName: "A síndrome do Imigrante.",

      describe1:
        "Uma zona quente, abafada e confusa onde você acha que é empresário porque abriu uma LLC — mas virou o empregado menos pago da empresa.",
      describe2:
        "E acha que vender seu trabalho 40% mais barato pra não ficar com o calendário vazio vai resolver seus problemas.",

      bridgeLead: "Mas aqui vai a verdade —",
      bridgeName: "Existe uma solução.",

      heroIntro: "Talvez você não saiba, mas nos olhos de um Americano…",
      heroLead: "Você é um",
      heroWord: "super herói",
      heroParen: "(E a pessoa certa que vai resolver os problemas dele).",
      traits: "Sua habilidade. Sua confiabilidade. Sua palavra.",
      traitsGold: "Isso é ouro.",

      promise:
        "Você só precisa do sistema certo pra transformar isso num fluxo constante de clientes, avaliações 5 estrelas e indicações que continuam chegando na palma das suas mãos — sem o caos.",

      ctaTitle: "Então, de onde você estiver começando…",
      ctaSubtitle: "Tudo começa escolhendo o seu caminho abaixo.",
      ctaPrimary: "Contrate-nos para fazer por você",
      ctaSecondary: "Aprenda a fazer você mesmo",
    };
---

<section class="py-24 md:py-32 bg-[#f4f4f5] text-zinc-900 border-t-8 border-primary">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="prose prose-lg md:prose-2xl mx-auto font-sans">
      <p class="font-bold text-2xl md:text-3xl mb-8">{t.hook}</p>

      <p class="mb-4 text-xl md:text-2xl font-medium text-zinc-700">{t.line1}</p>
      <p class="mb-4 text-xl md:text-2xl font-medium text-zinc-700">{t.line2}</p>
      <p class="mb-14 text-xl md:text-2xl font-medium text-zinc-700">{t.line3}</p>

      <p class="mb-6 text-xl md:text-2xl font-medium">{t.question}</p>

      <p class="mb-14 font-black text-3xl md:text-5xl leading-tight tracking-tight uppercase">
        {t.hardLead}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-red-800">
          {` ${t.hardWord}`}
        </span>.
        <br />
        <span class="border-b-4 border-primary pb-1">{t.hardEmphasis}</span>
      </p>

      <p class="mb-10 text-xl md:text-2xl leading-relaxed text-zinc-700">{t.pain1}</p>
      <p class="mb-10 text-xl md:text-2xl leading-relaxed text-zinc-700">{t.pain2}</p>
      <p class="mb-16 text-xl md:text-2xl leading-relaxed text-zinc-700">{t.pain3}</p>

      <p class="mb-14 text-xl md:text-2xl font-medium leading-relaxed text-zinc-800">
        {t.stressed}
      </p>

      <p class="mb-10 font-black text-3xl md:text-4xl uppercase tracking-tight">
        {t.everyoneHeader}
      </p>

      <div class="mb-14 border-l-4 border-primary pl-6 md:pl-8 space-y-4 text-xl md:text-2xl italic text-zinc-700">
        <p>{t.voice1}</p>
        <p>{t.voice2}</p>
        <p>{t.voice3}</p>
      </div>

      <p class="mb-6 text-xl md:text-2xl font-medium">{t.selfIntro}</p>

      <ul class="list-none mb-14 space-y-6 text-xl md:text-2xl font-medium text-zinc-800 border-l-4 border-primary pl-6 md:pl-8">
        <li>{t.q1}</li>
        <li>{t.q2}</li>
        <li>{t.q3}</li>
        <li>{t.q4}</li>
        <li>{t.q5}</li>
      </ul>

      <p class="mb-16 font-black text-3xl md:text-4xl text-red-600 italic uppercase text-center">
        {t.scream}
      </p>

      <p class="mb-8 text-xl md:text-2xl leading-relaxed">{t.notAlone}</p>
      <p class="mb-4 text-xl md:text-2xl leading-relaxed">{t.confused1}</p>
      <p class="mb-4 text-xl md:text-2xl leading-relaxed">{t.confused2}</p>
      <p class="mb-16 text-xl md:text-2xl leading-relaxed">{t.confused3}</p>

      <div class="text-center my-20">
        <p class="font-heading text-5xl md:text-7xl uppercase tracking-tighter mb-4">
          {t.callLead}
          <br />
          <span class="text-red-600 border-b-8 border-primary inline-block pb-2">
            {t.callName}
          </span>
        </p>
      </div>

      <p class="mb-10 text-xl md:text-2xl leading-relaxed text-center max-w-3xl mx-auto">
        {t.describe1}
      </p>
      <p class="mb-20 text-xl md:text-2xl font-bold leading-relaxed text-center max-w-3xl mx-auto">
        {t.describe2}
      </p>

      <p class="mb-4 text-xl md:text-2xl font-medium text-zinc-700 text-center">
        {t.bridgeLead}
      </p>
      <p class="mb-20 font-black text-3xl md:text-5xl uppercase tracking-tight text-center">
        <span class="border-b-4 border-primary pb-1">{t.bridgeName}</span>
      </p>

      <p class="mb-8 text-xl md:text-2xl leading-relaxed">{t.heroIntro}</p>

      <p class="mb-6 font-black text-3xl md:text-5xl leading-tight tracking-tight uppercase">
        {t.heroLead}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-green-600">
          {` ${t.heroWord}`}
        </span>.
      </p>
      <p class="mb-12 text-lg md:text-xl leading-relaxed italic text-zinc-600">
        {t.heroParen}
      </p>

      <p class="mb-4 text-xl md:text-2xl font-medium">{t.traits}</p>
      <p class="mb-16 font-black text-4xl md:text-5xl uppercase">
        <span class="text-zinc-950 border-b-8 border-primary inline-block pb-1">
          {t.traitsGold}
        </span>
      </p>

      <p class="mb-20 text-xl md:text-2xl leading-relaxed text-zinc-800">
        {t.promise}
      </p>

      <div class="bg-white border-4 border-zinc-950 rounded-xl p-8 md:p-12 mt-16 text-center shadow-[10px_10px_0px_0px_rgba(208,242,36,1)] transition-transform hover:-translate-y-1 hover:translate-x-1 hover:shadow-[5px_5px_0px_0px_rgba(208,242,36,1)]">
        <h3 class="font-heading text-4xl md:text-5xl uppercase tracking-tight mb-6">
          {t.ctaTitle}
        </h3>
        <p class="mb-10 text-xl font-medium text-zinc-600">{t.ctaSubtitle}</p>

        <div class="flex flex-col sm:flex-row justify-center gap-6 mt-4">
          <a
            href={isEs ? "/es/reuniao-sessao-estrategica" : "/reuniao-sessao-estrategica"}
            class="inline-flex h-16 items-center justify-center rounded-none bg-primary px-8 text-xl font-black text-zinc-950 shadow-md transition-colors hover:bg-[#bce01f] focus-visible:outline-none uppercase tracking-wider border-2 border-zinc-950"
          >
            {t.ctaPrimary}
          </a>
          <a
            href="/quantum-growth"
            class="inline-flex h-16 items-center justify-center rounded-none bg-zinc-950 px-8 text-xl font-black text-white shadow-md transition-colors hover:bg-zinc-800 focus-visible:outline-none uppercase tracking-wider"
          >
            {t.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
