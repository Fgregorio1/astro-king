# Copy this file to `.env` and fill in real values for local dev.
# In production these MUST be set in the Cloudflare dashboard:
#   Workers & Pages → astro-kingkong (and latinuspro) → Settings →
#   Variables and Secrets → (add each key as a Secret for production)
#
# Required
GHL_LOCATION_ID=
GHL_FORM_ID=
# Optional — only needed if you want a private integration token attached
GHL_API_KEY=
# Optional — set to "true" during development to log the outgoing GHL payload
DEBUG=false
