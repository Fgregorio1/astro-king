{
	"name": "astro-kingkong",
	"workers_dev": true,
	"preview_urls": true,
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-04-18",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
		"enabled": true
	}
}